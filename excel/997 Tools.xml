<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="TabDataAudit" label="997工具箱">
        <group id="GroupBorder" label="排版辅助">
          <button id="BtnBorder" label="外边框加粗" size="large" imageMso="BorderThickOutside" onAction="BtnBorder_Click" />
        </group>
            
        <group id="GroupTracker" label="修改追踪">
          <!-- 第一列：启动与停止（保持大图标） -->
          <button id="BtnStart" label="启动标记" size="large" imageMso="InkingStart" onAction="StartTracker_Click" getEnabled="GetEnabledState"/>
          <button id="BtnStop" label="停止标记" size="large" imageMso="InkDeleteAllInk" onAction="StopTracker_Click" getEnabled="GetEnabledState"/>
          
          <!-- 第二列：手动标记与标记删除（垂直排列） -->
          <box id="boxColumn1" boxStyle="vertical">
            <button id="BtnManualMark" label="手动标记" onAction="ManualMark_Click" imageMso="TextHighlightColorPicker" />
            <button id="BtnMarkDelete" label="标记删除" onAction="MarkDelete_Click" imageMso="Strikethrough" />
          </box>

          <!-- 第三列：三种清除功能（垂直排列） -->
          <box id="boxColumn2" boxStyle="vertical">
            <button id="BtnClearFormatsOnly" label="清除标记格式" onAction="ClearFormatsOnly_Click" imageMso="ClearFormats" />
            <button id="BtnClearMarksAndDates" label="清除格式及日期" onAction="ClearMarksAndDates_Click" imageMso="DeleteRows" />
            <button id="BtnClearManualSelection" label="手动清除" onAction="ClearManualSelection_Click" imageMso="Clear" />
          </box>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
